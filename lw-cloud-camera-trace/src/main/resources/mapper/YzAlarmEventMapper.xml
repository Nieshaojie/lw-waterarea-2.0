<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mskyeye.trace.mapper.YzAlarmEventMapper">

    <resultMap type="YzAlarmEvent" id="YzAlarmEventResult">
        <result property="id" column="id"/>
        <result property="cameraId" column="camera_id"/>
        <result property="deptId" column="dept_id"/>
        <result property="eventType" column="event_type"/>
        <result property="status" column="status"/>
        <result property="lon" column="lon"/>
        <result property="lat" column="lat"/>
        <result property="alarmTime" column="alarm_time"/>
        <result property="photoUrl1" column="photo_url1"/>
        <result property="photoUrl2" column="photo_url2"/>
        <result property="photoUrl3" column="photo_url3"/>
        <result property="photoUrl4" column="photo_url4"/>
        <result property="photoUrl5" column="photo_url5"/>
        <result property="videoUrl" column="video_url"/>
        <result property="aiPointName" column="ai_point_name"/>
    </resultMap>

    <sql id="selectYzAlarmEventVo">
        select id,
               camera_id,
               dept_id,
               event_type,
               status,
               lon,
               lat,
               alarm_time,
               photo_url1,
               photo_url2,
               photo_url3,
               photo_url4,
               photo_url5,
               video_url,
               ai_point_name
        from yz_alarm_event
    </sql>

    <insert id="insertYzAlarmEvent" parameterType="YzAlarmEvent" useGeneratedKeys="true" keyProperty="id">
        insert into yz_alarm_event
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cameraId != null">camera_id,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="eventType != null">event_type,</if>
            <if test="status != null">status,</if>
            <if test="lon != null">lon,</if>
            <if test="lat != null">lat,</if>
            <if test="alarmTime != null">alarm_time,</if>
            <if test="photoUrl1 != null">photo_url1,</if>
            <if test="photoUrl2 != null">photo_url2,</if>
            <if test="photoUrl3 != null">photo_url3,</if>
            <if test="photoUrl4 != null">photo_url4,</if>
            <if test="photoUrl5 != null">photo_url5,</if>
            <if test="videoUrl != null">video_url,</if>
            <if test="aiPointName != null">ai_point_name,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="cameraId != null">#{cameraId},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="eventType != null">#{eventType},</if>
            <if test="status != null">#{status},</if>
            <if test="lon != null">#{lon},</if>
            <if test="lat != null">#{lat},</if>
            <if test="alarmTime != null">#{alarmTime},</if>
            <if test="photoUrl1 != null">#{photoUrl1},</if>
            <if test="photoUrl2 != null">#{photoUrl2},</if>
            <if test="photoUrl3 != null">#{photoUrl3},</if>
            <if test="photoUrl4 != null">#{photoUrl4},</if>
            <if test="photoUrl5 != null">#{photoUrl5},</if>
            <if test="videoUrl != null">#{videoUrl},</if>
            <if test="aiPointName != null">#{aiPointName},</if>
        </trim>
    </insert>
</mapper>